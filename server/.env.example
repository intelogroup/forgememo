# ── Auth (required) ───────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FORGEMEM_JWT_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and service role key from: Supabase dashboard → Settings → API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Email (required for magic links) ─────────────────────────────────────────
# Resend: https://resend.com — free tier covers early usage
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@forgemem.com

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# ── OAuth providers ───────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Server config ─────────────────────────────────────────────────────────────
FREE_CREDIT_USD=5.00
PLATFORM_FEE_USD=0.02
RATE_LIMIT_PER_HOUR=60
API_BASE_URL=https://api.forgemem.com
WEBAPP_ORIGIN=http://localhost:3000
